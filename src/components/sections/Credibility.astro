---
import statsData from '../../data/stats.json';
import type { StatsData, StatItem } from '../../types';

const stats = statsData as StatsData;
---

<section class="section-padding bg-[var(--color-surface)]" aria-label="Números da Kings Neon">
  <div class="container-wide">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-space-6 md:gap-space-8" data-stagger>
      {stats.items.map((stat: StatItem) => (
        <div class="stat-card text-center p-space-6 md:p-space-8 rounded-lg bg-[var(--color-surface-2)] border border-[var(--color-border-subtle)]">
          <p class="font-display text-fluid-2xl font-bold text-[var(--color-accent)] leading-none mb-space-2">
            {stat.prefix && <span class="text-fluid-lg">{stat.prefix}</span>}
            <span class="stat-value">{stat.value}</span>
            {stat.suffix && <span>{stat.suffix}</span>}
          </p>
          <p class="text-fluid-sm text-[var(--color-text-muted)]">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
