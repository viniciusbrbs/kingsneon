---
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import navigationData from '../../data/navigation.json';
import type { NavigationData } from '../../types';

const nav = navigationData as NavigationData;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-[110] transition-all duration-300" role="banner">
  <div class="container-wide py-4">
    <div class="glass-panel rounded-2xl px-4 md:px-6 h-16 md:h-20 flex items-center justify-between">
      <a href="/" class="relative z-[120] flex-shrink-0" aria-label="Kings Neon — Página inicial">
        <img src="/brand/logo-white.svg" alt="Kings Neon" width="148" height="40" class="h-8 md:h-10 w-auto" />
      </a>

      <nav class="hidden md:flex items-center gap-8" aria-label="Navegação principal">
        {nav.items.map((item) => (
          <a
            href={item.href}
            class="text-fluid-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] font-body font-medium transition-colors"
            {...(item.isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden md:flex items-center gap-3">
        <Button label={nav.ctaLabel} href={nav.ctaHref} variant="primary" size="sm" icon="whatsapp" />
      </div>

      <button
        id="mobile-menu-toggle"
        class="relative z-[120] flex md:hidden items-center justify-center w-11 h-11 rounded-xl border border-[var(--color-border)] bg-[rgba(7,17,31,0.9)] hover:bg-[rgba(13,27,49,1)]"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span id="menu-icon-open"><Icon name="menu" size={24} /></span>
        <span id="menu-icon-close" class="hidden"><Icon name="x" size={24} /></span>
      </button>
    </div>
  </div>
</header>

<div id="mobile-menu" class="mobile-menu fixed inset-0 z-[100] flex flex-col md:hidden" aria-label="Menu mobile" role="dialog" aria-modal="true" hidden>
  <div class="mobile-menu-backdrop absolute inset-0"></div>
  <nav class="mobile-menu-content relative z-[101] flex flex-col items-center justify-center flex-1 gap-space-6 text-center px-space-6">
    {nav.items.map((item) => (
      <a
        href={item.href}
        class="mobile-nav-link text-fluid-xl text-[var(--color-text)] font-display font-semibold hover:text-[var(--color-accent)] transition-colors"
        {...(item.isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {item.label}
      </a>
    ))}
    <div class="mobile-nav-link mt-space-4 flex flex-col items-center gap-4">
      <Button label={nav.ctaLabel} href={nav.ctaHref} variant="primary" size="lg" icon="whatsapp" />
    </div>
  </nav>
</div>

<div class="h-24 md:h-28" aria-hidden="true"></div>

<style>
#site-header.scrolled { transform: translateY(0); }
.mobile-menu { opacity: 0; pointer-events: none; transition: opacity var(--duration-base) var(--ease-out-expo); }
.mobile-menu.open { opacity: 1; pointer-events: auto; }
.mobile-menu-backdrop {
  background: linear-gradient(180deg, rgba(1,2,0,0.8), rgba(7,17,31,0.96));
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
}
.mobile-menu-content { min-height: 100dvh; }
.mobile-menu .mobile-nav-link {
  opacity: 0; transform: translateY(16px);
  transition: opacity var(--duration-slow) var(--ease-out-expo), transform var(--duration-slow) var(--ease-out-expo);
}
.mobile-menu.open .mobile-nav-link { opacity: 1; transform: translateY(0); }
.mobile-menu.open .mobile-nav-link:nth-child(1) { transition-delay: 100ms; }
.mobile-menu.open .mobile-nav-link:nth-child(2) { transition-delay: 160ms; }
.mobile-menu.open .mobile-nav-link:nth-child(3) { transition-delay: 220ms; }
.mobile-menu.open .mobile-nav-link:nth-child(4) { transition-delay: 280ms; }
.mobile-menu.open .mobile-nav-link:nth-child(5) { transition-delay: 340ms; }
</style>

<script>
const toggle = document.getElementById('mobile-menu-toggle');
const menu = document.getElementById('mobile-menu');
const iconOpen = document.getElementById('menu-icon-open');
const iconClose = document.getElementById('menu-icon-close');
let isOpen = false;
function setMenu(open) {
  isOpen = open;
  toggle?.setAttribute('aria-expanded', String(open));
  toggle?.setAttribute('aria-label', open ? 'Fechar menu' : 'Abrir menu');
  iconOpen?.classList.toggle('hidden', open);
  iconClose?.classList.toggle('hidden', !open);
  if (open) {
    menu?.removeAttribute('hidden');
    requestAnimationFrame(() => menu?.classList.add('open'));
    document.body.style.overflow = 'hidden';
  } else {
    menu?.classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(() => { if (!isOpen) menu?.setAttribute('hidden', ''); }, 300);
  }
}

toggle?.addEventListener('click', () => setMenu(!isOpen));
menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => setMenu(false)));
document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) setMenu(false); });
</script>
